{
  "entities": {
    "Product": {
      "title": "Producto",
      "description": "Plato o bebida del catálogo",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Nombre del plato" },
        "price": { "type": "number", "description": "Precio de venta" },
        "category": { "type": "string", "description": "Categoría (Entradas, Fuertes, etc.)" },
        "description": { "type": "string", "description": "Descripción del plato" },
        "imageId": { "type": "string", "description": "ID de Google Drive de la imagen" },
        "recipe": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "ingredientId": { "type": "string" },
              "quantity": { "type": "number" }
            }
          },
          "description": "Lista de insumos y cantidades por plato"
        },
        "active": { "type": "boolean", "description": "Si está visible en el catálogo" }
      },
      "required": ["name", "price", "category"]
    },
    "Ingredient": {
      "title": "Insumo",
      "description": "Materia prima para las recetas",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Nombre del insumo" },
        "stock": { "type": "number", "description": "Cantidad actual en inventario" },
        "unit": { "type": "string", "description": "Unidad de medida (kg, gr, und, etc.)" },
        "minStock": { "type": "number", "description": "Stock mínimo para alertas" }
      },
      "required": ["name", "stock", "unit"]
    },
    "Sale": {
      "title": "Venta",
      "description": "Registro de una transacción en el TPV",
      "type": "object",
      "properties": {
        "items": { "type": "array", "items": { "type": "object" } },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "clientName": { "type": "string" },
        "table": { "type": "string" }
      },
      "required": ["items", "total", "timestamp"]
    },
    "Expense": {
      "title": "Gasto",
      "description": "Registro de egresos",
      "type": "object",
      "properties": {
        "concept": { "type": "string" },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["concept", "amount", "timestamp"]
    },
    "Table": {
      "title": "Mesa",
      "description": "Estado de una mesa en el restaurante",
      "type": "object",
      "properties": {
        "number": { "type": "integer" },
        "items": { "type": "array", "items": { "type": "object" } },
        "clientName": { "type": "string" },
        "status": { "type": "string", "enum": ["free", "busy"] },
        "lastUpdate": { "type": "string", "format": "date-time" }
      },
      "required": ["number", "status"]
    },
    "BusinessSettings": {
      "title": "Configuración del Negocio",
      "description": "Datos generales y parámetros del restaurante",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Nombre del negocio" },
        "address": { "type": "string", "description": "Dirección física" },
        "phone": { "type": "string", "description": "Teléfono de contacto" },
        "whatsapp": { "type": "string", "description": "Número de WhatsApp para pedidos (con código de país)" },
        "tableCount": { "type": "integer", "description": "Número total de mesas en el TPV" },
        "currencySymbol": { "type": "string", "description": "Símbolo de moneda (e.g., $)" }
      },
      "required": ["name", "whatsapp", "tableCount"]
    },
    "Customer": {
      "title": "Cliente",
      "description": "Información de contacto de clientes para domicilios",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Nombre del cliente" },
        "phone": { "type": "string", "description": "Teléfono del cliente" },
        "address": { "type": "string", "description": "Dirección de entrega" },
        "notes": { "type": "string", "description": "Notas o referencias de entrega" },
        "lastOrder": { "type": "string", "format": "date-time", "description": "Fecha del último pedido" }
      },
      "required": ["name", "phone", "address"]
    },
    "AIConversation": {
      "title": "Conversación IA",
      "description": "Historial de chat guardado con la IA",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "createdAt", "updatedAt"]
    },
    "AIMessage": {
      "title": "Mensaje IA",
      "description": "Mensaje individual dentro de una conversación",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model"] },
        "parts": { "type": "array", "items": { "type": "object" } },
        "timestamp": { "type": "number" }
      },
      "required": ["role", "parts", "timestamp"]
    }
  },
  "firestore": {
    "/products/{productId}": { "schema": "Product", "description": "Catálogo de productos" },
    "/ingredients/{ingredientId}": { "schema": "Ingredient", "description": "Inventario de insumos" },
    "/sales/{saleId}": { "schema": "Sale", "description": "Historial de ventas" },
    "/expenses/{expenseId}": { "schema": "Expense", "description": "Registro de gastos" },
    "/tables/{tableId}": { "schema": "Table", "description": "Estado de las mesas" },
    "/settings/business": { "schema": "BusinessSettings", "description": "Configuración global del negocio" },
    "/customers/{phone}": { "schema": "Customer", "description": "Directorio de clientes para domicilios" },
    "/chats/{chatId}": { "schema": "AIConversation", "description": "Conversaciones guardadas con Pepa Intelligence" },
    "/chats/{chatId}/messages/{messageId}": { "schema": "AIMessage", "description": "Mensajes de la conversación" }
  }
}
